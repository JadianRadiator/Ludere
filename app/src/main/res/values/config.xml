<?xml version="1.0" encoding="utf-8"?>
<resources>

    <string name="config_id">pokemonshinygoldsigma</string>

    <string name="config_name">Pokémon Shiny Gold Sigma</string>

    <string name="config_core">mgba</string>

    <!-- GBA ROMs are too large to benefit from loading entirely into RAM -->
    <bool name="config_load_bytes">false</bool>

    <!-- mGBA Core Options -->
    <string name="config_variables">
        mgba_idle_optimization=Remove Known,
        mgba_frameskip=disabled,
        mgba_solar_sensor_level=0,
        mgba_allow_opposing_directions=disabled
    </string>

    <!-- Faster grinding -->
    <integer name="config_fast_forward_multiplier">4</integer>

    <bool name="config_fullscreen">true</bool>

    <!-- Landscape -->
    <integer name="config_orientation">2</integer>

    <bool name="config_gamepad">true</bool>

    <!-- Disable vibration for battery -->
    <bool name="config_gamepad_haptic">false</bool>

    <bool name="config_gamepad_a">true</bool>
    <bool name="config_gamepad_b">true</bool>

    <!-- Turbo buttons not needed -->
    <bool name="config_gamepad_x">false</bool>
    <bool name="config_gamepad_y">false</bool>

    <bool name="config_gamepad_start">true</bool>
    <bool name="config_gamepad_select">true</bool>

    <bool name="config_gamepad_l1">true</bool>
    <bool name="config_gamepad_r1">true</bool>

    <!-- Pokémon plays best with a D-pad -->
    <bool name="config_left_analog">false</bool>

</resources>
